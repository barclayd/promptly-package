{
  "name": "@promptlycms/prompts",
  "version": "0.5.0",
  "description": "TypeScript SDK for Promptly CMS — fetch prompts, build Zod schemas, generate typed code",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "require": "./dist/schema.cjs"
    }
  },
  "bin": {
    "promptly": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check": "bun run types && bun run lint && bun run test",
    "types": "tsgo --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test src/__tests__/client src/__tests__/codegen src/__tests__/composer src/__tests__/generate src/__tests__/schema",
    "test:smoke": "bun test src/__tests__/smoke.test.ts",
    "test:watch": "bun test --watch",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "citty": "^0.2.1"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/mistral": "^3.0.27",
    "@ai-sdk/openai": "^3.0.48",
    "@biomejs/biome": "^2.4.8",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "1.3.11",
    "@typescript/native-preview": "^7.0.0-dev.20260323.1",
    "ai": "^6.0.137",
    "tsup": "^8.5.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "typescript": "^5.0.0 || ^6.0.0",
    "zod": "^4.0.0",
    "ai": "^6.0.137"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/mistral": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/barclayd/promptly-package"
  },
  "publishConfig": {
    "access": "public"
  }
}
